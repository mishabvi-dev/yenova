{
  "rewrites": [
    {
      "source": "/lms/:match*",
      "destination": "https://web-yenova.vercel.app/:match*"
    },
    {
      "source": "/lms",
      "destination": "https://web-yenova.vercel.app"
    },
    {
      "source": "/_next/:match*",
      "destination": "https://web-yenova.vercel.app/_next/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
